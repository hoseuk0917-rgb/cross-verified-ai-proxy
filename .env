# Cross-Verified AI Proxy Server 환경 설정
# 이 파일을 수정하여 사용하세요

# 서버 포트
PORT=3000

# 개발 모드
NODE_ENV=development

# 마스터 비밀번호 (API Key 암호화용)
# ⚠️ 프로덕션에서는 반드시 변경하세요!
MASTER_PASSWORD=default-master-password-change-this

# Rate Limiting 설정
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 선택 사항 - 필요시 주석 해제하고 사용
# ============================================

# Gemini API Key (Google AI Studio에서 발급)
# GEMINI_API_KEY=your-gemini-api-key-here

# GitHub API Token (선택 - Rate Limit 향상)
# GITHUB_TOKEN=your-github-token-here

# K-Law API Key (선택 - 법령정보)
# KLAW_API_KEY=your-klaw-api-key-here
